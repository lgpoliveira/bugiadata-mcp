{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.lgpoliveira/bugiadata-mcp",
  "title": "BugiaData",
  "description": "Locale-aware fake data and relational multi-table datasets via MCP. Tools: ping, whoami, generate_data, generate_relational_data. Free tier available at bugiadata.com.",
  "version": "1.0.0",
  "websiteUrl": "https://bugiadata.com/mcp",
  "repository": {
    "url": "https://github.com/lgpoliveira/bugiadata-mcp",
    "source": "github"
  },
  "remotes": [
    {
      "type": "sse",
      "url": "https://mcp.bugiadata.com/sse",
      "headers": [
        {
          "name": "X-API-Key",
          "description": "BugiaData API key from https://bugiadata.com/dashboard?tab=mcp",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
