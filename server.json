{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.lgpoliveira/bugiadata-mcp",
  "title": "BugiaData",
  "description": "Relational locale-aware fake data for Cursor and Claude via MCP (SSE). Free tier at bugiadata.com.",
  "version": "1.0.0",
  "websiteUrl": "https://bugiadata.com/mcp",
  "repository": {
    "url": "https://github.com/lgpoliveira/bugiadata-mcp",
    "source": "github"
  },
  "remotes": [
    {
      "type": "sse",
      "url": "https://mcp.bugiadata.com/sse",
      "headers": [
        {
          "name": "X-API-Key",
          "description": "BugiaData API key from https://bugiadata.com/dashboard?tab=mcp",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
